-- Get Key Logic (Copy to Clipboard)
GetKeyBtn.MouseButton1Click:Connect(function()
    if setclipboard then
        setclipboard(KeyLink)
        GetKeyBtn.Text = "COPIED!"
        task.wait(2)
        GetKeyBtn.Text = "GET KEY"
    else
        GetKeyBtn.Text = "ERROR"
    end
end)

-- Submit Logic
SubmitBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == CorrectKey then
        SubmitBtn.Text = "SUCCESS"
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(40, 200, 100)
        task.wait(1)
        ScreenGui:Destroy()
        -- Dito mo ilagay ang main script mo
        print("Unlocked!")
    else
        SubmitBtn.Text = "WRONG"
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        task.wait(1.5)
        SubmitBtn.Text = "SUBMIT"
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(70, 130, 255)
    end
end)
